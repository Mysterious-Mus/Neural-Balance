{
  "name": "ML Container",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "runArgs": [
    "--gpus", "all",
    "--ipc=host",
    "--shm-size=16g"
  ],
  "mounts": [
    "source=${localEnv:HOME}/.cache,target=/root/.cache,type=bind,consistency=cached"
  ],
  "forwardPorts": [8000, 5900],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3"
      }
    }
  },
  "remoteUser": "root"
}
